# Antigravity Observer — Bridge environment template
# Copy this file to bridge/.env and fill in real values. The .env file is
# gitignored; this .env.example is the committable, secret-free guide.

# REQUIRED: unique, strong secret for the auth-token handshake.
# Must MATCH the token set in the extension (Plugins > Mission Security,
# or the GENERATE STRONG TOKEN button). No default is shipped anymore —
# do NOT reuse the legacy "antgr_secret_v1_99" value.
AUTH_TOKEN=

# WebSocket port the Bridge listens on.
PORT=3001

# Local Brain (Ollama) generate endpoint.
OLLAMA_URL=http://localhost:11434/api/generate

# Default local model served by Ollama.
DEFAULT_MODEL=llama3:latest

# OPTIONAL: Remote Brain (Google Gemini) API key. Leave empty to disable remote failover.
GEMINI_API_KEY=

# Remote model name used when failing over to the Remote Brain.
REMOTE_MODEL=gemini-2.5-flash

# OPTIONAL: admin password gate. If set, the Bridge prompts for it on startup.
SERVER_PASSWORD=
